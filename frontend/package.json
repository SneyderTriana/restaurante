{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",

    "lint": "eslint src",
    "lint:fix": "eslint src --fix",

    "format": "prettier --write \"src/**/*.{js,jsx,css}\"",

    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },

  "dependencies": {
    "axios": "^1.16.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0"
  },

  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.12",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}